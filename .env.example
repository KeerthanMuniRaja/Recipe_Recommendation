# ─────────────────────────────────────────────────────────
# Recipe GenAI System — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────
# Options: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Number of retrieved recipes included in LLM context
LLM_CONTEXT_RECIPES=3

# ── Embedding Model ───────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIM=384
EMBEDDING_BATCH_SIZE=64
MAX_SEQ_LENGTH=256

# ── FAISS / Retrieval ─────────────────────────────────────
RETRIEVAL_TOP_K=5
# Options: "flat" (exact, best for <100k) or "ivf" (approx, faster for 100k+)
FAISS_INDEX_TYPE=flat
FAISS_NLIST=100
SCORE_THRESHOLD=0.2

# ── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_RELOAD=false
API_LOG_LEVEL=info
# Comma-separated allowed CORS origins
CORS_ORIGINS=*

# ── Data Preprocessing ────────────────────────────────────
MIN_INGREDIENTS=2
MAX_INGREDIENTS=30
# Uncomment to limit recipes loaded (useful for dev/testing)
# MAX_RECIPES=5000
